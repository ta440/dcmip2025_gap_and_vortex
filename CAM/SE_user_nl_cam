omega = 0 ! No Coriolis
!sday = 4308.2 ! With Coriolis. Defines omega=2*pi/sday. Scale by 1/X, with the base sday is 86164.1 s.

! Remove (or make negligibly small) the Laplacian
! sponge layer at the model top
